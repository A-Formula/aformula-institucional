# Apache / cPanel / hospedagem compartilhada
# Cole na raiz do site (public_html/). Requer mod_headers, mod_deflate, mod_expires.

# ---------- SEGURANCA ----------
<IfModule mod_headers.c>
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(self), payment=()"
  # HSTS — ative so depois de confirmar HTTPS funcionando 100%
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  # CSP — 'unsafe-inline' e necessario (site tem 808 inline styles + scripts inline herdados do Claude Design)
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https:; frame-ancestors 'self'; base-uri 'self'; form-action 'self' mailto:; object-src 'none'; upgrade-insecure-requests"
  # Remove header que revela versao do servidor
  Header unset X-Powered-By
</IfModule>

# ---------- COMPRESSAO (GZIP) ----------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# ---------- CACHE ----------
<IfModule mod_expires.c>
  ExpiresActive On
  # Assets versionados: 1 ano imutavel
  ExpiresByType image/webp        "access plus 1 year"
  ExpiresByType image/jpeg        "access plus 1 year"
  ExpiresByType image/png         "access plus 1 year"
  ExpiresByType image/svg+xml     "access plus 1 year"
  ExpiresByType font/woff2        "access plus 1 year"
  ExpiresByType font/woff         "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/css          "access plus 1 month"
  # HTML: sempre revalida
  ExpiresByType text/html         "access plus 0 seconds"
</IfModule>

# ---------- HTTPS forcado (descomente quando tiver SSL) ----------
# <IfModule mod_rewrite.c>
#   RewriteEngine On
#   RewriteCond %{HTTPS} off
#   RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
# </IfModule>

# Bloqueia listagem de diretorios
Options -Indexes
