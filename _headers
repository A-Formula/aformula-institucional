## Netlify / Vercel (via netlify.toml ou como arquivo _headers no output)
## Cole na raiz do deploy. Cobre TODAS as rotas.

/*
  ## Impede clickjacking (embed do site em iframe de terceiros)
  X-Frame-Options: SAMEORIGIN
  ## Impede o browser de "adivinhar" tipo de arquivo (MIME sniffing)
  X-Content-Type-Options: nosniff
  ## Nao vaza a URL de origem completa para sites externos
  Referrer-Policy: strict-origin-when-cross-origin
  ## Bloqueia APIs sensiveis que o site nao usa
  Permissions-Policy: camera=(), microphone=(), geolocation=(self), payment=()
  ## Forca HTTPS por 1 ano (so ative depois de confirmar que HTTPS funciona 100%)
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  ## Content Security Policy — o site usa muito inline style/script (herdado do Claude Design),
  ## por isso 'unsafe-inline' e necessario. Fontes externas: Google Fonts. Mapa: maplibre (tiles).
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https:; frame-ancestors 'self'; base-uri 'self'; form-action 'self' mailto:; object-src 'none'; upgrade-insecure-requests

## Cache agressivo para assets versionados (imagens, fonts, js, css)
## Sao imutaveis na pratica — se trocar, o nome muda.
/*_assets/*
  Cache-Control: public, max-age=31536000, immutable

/assets/*
  Cache-Control: public, max-age=31536000, immutable

## HTML nunca em cache longo (conteudo muda)
/*.html
  Cache-Control: public, max-age=0, must-revalidate
