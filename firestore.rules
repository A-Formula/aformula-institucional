rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // admin = existe doc admins/{email} do usuário autenticado
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }

    // Coleções de conteúdo (CMS): leitura pública p/ o build ler; escrita só admin.
    match /posts/{doc}          { allow read: if true; allow write: if isAdmin(); }
    match /categories/{doc}     { allow read: if true; allow write: if isAdmin(); }
    match /banners/{doc}        { allow read: if true; allow write: if isAdmin(); }
    match /settings/{doc}       { allow read: if true; allow write: if isAdmin(); }
    match /pages/{doc}          { allow read: if true; allow write: if isAdmin(); }
    match /stores/{doc}         { allow read: if true; allow write: if isAdmin(); }

    // Submissões: criação via API (admin SDK ignora rules); leitura/edição só admin no painel.
    match /contact_messages/{doc} { allow read, update: if isAdmin(); allow create: if false; }
    match /prescribers/{doc}      { allow read, update: if isAdmin(); allow create: if false; }
    match /newsletter/{doc}       { allow read: if isAdmin(); allow create: if false; }
    match /prescriber_blocked_attempts/{doc} { allow read: if isAdmin(); allow write: if false; }

    // Área do prescritor (F4): aprovado = existe prescriber_access/{email} (criado na aprovação).
    function isApprovedPrescriber() {
      return request.auth != null
        && exists(/databases/$(database)/documents/prescriber_access/$(request.auth.token.email));
    }
    match /prescriber_content/{doc} {
      allow read: if isApprovedPrescriber() || isAdmin();
      allow write: if isAdmin();
    }
    match /prescriber_access/{email} {
      allow read: if isAdmin() || (request.auth != null && request.auth.token.email == email);
      allow write: if false; // só via API de aprovação (admin SDK)
    }

    // Allowlist de admins: cada um lê o próprio doc (p/ confirmar acesso); nunca escreve.
    match /admins/{email}       { allow read: if request.auth != null && request.auth.token.email == email; allow write: if false; }

    match /{document=**}        { allow read, write: if false; }
  }
}
