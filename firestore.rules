rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // F1: todo acesso do site passa pelas Vercel Functions (firebase-admin, que ignora rules).
    // Cliente browser não lê nem escreve nada por enquanto — abre-se coleção a coleção
    // quando o cms-loader (F3) entrar: conteúdo vira read público, submissões seguem fechadas.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
