{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "node scripts/build-site.mjs",
  "outputDirectory": ".",
  "cleanUrls": true,
  "redirects": [
    { "source": "/blog/saude/saiba-a-importancia-da-imunidade", "destination": "/blog/saude/suplementos-para-aumentar-a-imunidade", "permanent": true },
    { "source": "/blog/saude/saiba-a-importancia-da-imunidade/", "destination": "/blog/saude/suplementos-para-aumentar-a-imunidade", "permanent": true },
    { "source": "/blog/saude/como-aumentar-a-imunidade-com-habitos-saudaveis", "destination": "/blog/saude/suplementos-para-aumentar-a-imunidade", "permanent": true },
    { "source": "/blog/saude/como-aumentar-a-imunidade-com-habitos-saudaveis/", "destination": "/blog/saude/suplementos-para-aumentar-a-imunidade", "permanent": true },
    { "source": "/blog/saude/conheca-suplementos-que-vao-te-ajudar-a-perder-peso", "destination": "/blog/saude/como-perder-peso-com-ajuda-de-suplementos-naturais", "permanent": true },
    { "source": "/blog/saude/conheca-suplementos-que-vao-te-ajudar-a-perder-peso/", "destination": "/blog/saude/como-perder-peso-com-ajuda-de-suplementos-naturais", "permanent": true },
    { "source": "/blog/saude/bcaa-tem-beneficios-que-vao-alem-da-melhora-nos-exercicios", "destination": "/blog/saude/o-poder-do-bcaa-conheca-os-impactos-positivos-no-seu-corpo", "permanent": true },
    { "source": "/blog/saude/bcaa-tem-beneficios-que-vao-alem-da-melhora-nos-exercicios/", "destination": "/blog/saude/o-poder-do-bcaa-conheca-os-impactos-positivos-no-seu-corpo", "permanent": true },
    { "source": "/blog/saude/conheca-os-beneficios-do-bcaa", "destination": "/blog/saude/o-poder-do-bcaa-conheca-os-impactos-positivos-no-seu-corpo", "permanent": true },
    { "source": "/blog/saude/conheca-os-beneficios-do-bcaa/", "destination": "/blog/saude/o-poder-do-bcaa-conheca-os-impactos-positivos-no-seu-corpo", "permanent": true },
    { "source": "/blog/saude/beneficios-do-cha-no-verao", "destination": "/blog/cuidados-com-o-corpo/chas-para-desintoxicar-conheca-os-beneficios-dessa-bebida-para-o-verao", "permanent": true },
    { "source": "/blog/saude/beneficios-do-cha-no-verao/", "destination": "/blog/cuidados-com-o-corpo/chas-para-desintoxicar-conheca-os-beneficios-dessa-bebida-para-o-verao", "permanent": true },
    { "source": "/blog/mercado/franquias-destaques-para-investimento-2021", "destination": "/blog/mercado/tudo-o-que-voce-precisa-saber-sobre-franquias", "permanent": true },
    { "source": "/blog/mercado/franquias-destaques-para-investimento-2021/", "destination": "/blog/mercado/tudo-o-que-voce-precisa-saber-sobre-franquias", "permanent": true },
    { "source": "/manipule-sua-receita", "destination": "/receita", "permanent": true },
    { "source": "/fale-conosco", "destination": "/contato", "permanent": true },
    { "source": "/trabalhe-conosco", "destination": "/contato", "permanent": true },
    { "source": "/login", "destination": "/area-do-prescritor", "permanent": true }
  ],
  "rewrites": [
    { "source": "/rj", "destination": "https://a-formula-br.vercel.app/rj" },
    { "source": "/rj/:path*", "destination": "https://a-formula-br.vercel.app/rj/:path*" },
    { "source": "/bh", "destination": "https://a-formula-br.vercel.app/bh" },
    { "source": "/bh/:path*", "destination": "https://a-formula-br.vercel.app/bh/:path*" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(self), payment=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' blob: https://www.google.com/recaptcha/ https://www.gstatic.com/recaptcha/; worker-src 'self' blob:; child-src 'self' blob: https://www.google.com/recaptcha/ https://recaptcha.google.com/recaptcha/; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https:; frame-ancestors 'self'; base-uri 'self'; form-action 'self' mailto:; object-src 'none'; upgrade-insecure-requests" }
      ]
    },
    {
      "source": "/(.*)_assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
